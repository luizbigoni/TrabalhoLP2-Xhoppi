<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <link rel="stylesheet" type="text/css" href="/css/style.css">
    <title>Xhopii - Editar Produto</title>
</head>

<body>

<header>
    <section id="cabecalho-logo">
        <img src="/img/logo.png" alt="Logo">
        <h1>Xhopii</h1>
    </section>
    <section id="cabecalho-logout">
        <a href="/login">Sair</a>
    </section>
</header>

<nav class="menu-horizontal">
    <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/clientes/cadastrar">Cadastro Cliente</a></li>
        <li><a href="/funcionario/cadastrar">Cadastro Funcionário</a></li>
        <li><a href="/produto/cadastrar">Cadastro Produto</a></li>
        <li><a href="/cupom/cadastrar">Cadastro Cupom</a></li>
        <li><a href="/clientes-list">Ver Clientes</a></li>
        <li><a href="/funcionarios-list">Ver Funcionários</a></li>
        <li><a href="/produtos-list">Ver Produtos</a></li>
        <li><a href="/cupons-list">Ver Cupons</a></li>
    </ul>
</nav>

<section class="conteudo-cadastro">
    <section class="conteudo-formulario-cadastro">
        
        <form id="form-editar" enctype="multipart/form-data">
            <label>Editar Produto</label>

            <!-- ID escondido -->
            <input type="hidden" id="produtoId" value="<%= produto._id %>">

            <input type="text" 
                   id="nome" 
                   placeholder="Nome do Produto" 
                   value="<%= produto.nome %>" 
                   required>

            <input type="text" 
                   id="fabricante" 
                   placeholder="Fabricante" 
                   value="<%= produto.fabricante %>" 
                   required>

            <input type="text" 
                   id="descricao" 
                   placeholder="Descrição" 
                   value="<%= produto.descricao %>" 
                   required>

            <input type="text" 
                   id="valor" 
                   placeholder="Valor (R$)" 
                   value="<%= produto.valor %>" 
                   required>

            <input type="number" 
                   id="quantidade" 
                   placeholder="Quantidade" 
                   value="<%= produto.quantidade %>" 
                   required>

            <label>Foto atual:</label>
            <img src="/img/<%= produto.foto %>" width="120" style="margin: 10px 0; border-radius: 8px;">

            <label>Alterar foto:</label>
            <input type="file" id="foto" accept="image/*">

            <button type="submit" 
                id="btn-salvar"
                style="padding: 10px; background-color: #ff6600; color: white; border: none; cursor: pointer;">
                Salvar Alterações
            </button>
        </form>

    </section>
</section>

<script src="/js/editar.js"></script>

</body>
</html>