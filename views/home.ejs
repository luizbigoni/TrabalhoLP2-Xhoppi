<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <link rel="stylesheet" type="text/css" href="/css/style.css">
    <link rel="icon" href="/img/logo.png" type="image/png">
    <title>Xhopii - Home</title>
</head>
<body>

<header>
    <section id="cabecalho-logo">
        <img src="/img/logo.png">
        <h1>Xhopii</h1>
    </section>
    <section id="cabecalho-logout">
        <a href="/logout">Sair</a>
    </section>
</header>

<nav class="menu-horizontal">
    <ul>
        <li><a href="/">Home</a></li>
         <li><a href="/clientes/cadastrar">Cadastro Cliente</a></li> 
        <li><a href="/funcionario/cadastrar">Cadastro Funcionário</a></li>
        <li><a href="/produto/cadastrar">Cadastro Produto</a></li>
        <li><a href="/cupom/cadastrar">Cadastro Cupom</a></li>
        <li><a href="/clientes-list">Ver Clientes</a></li>
        <li><a href="/funcionarios-list">Ver Funcionários</a></li>
        <li><a href="/produtos-list">Ver Produtos</a></li>
        <li><a href="/cupons-list">Ver Cupons</a></li>
    </ul>
</nav>

<section class="conteudo-home">
    <section class="conteudo-home-carousel">
        <img id="img-carousel" src="/img/carousel-1.jpg">
    </section>

    <img src="/img/home-promocao.png">

    <section class="conteudo-home-descobertas">
        <section class="conteudo-home-descobertas-titulo">
            <h1>Descobertas do dia</h1>
            <hr>
        </section>

        <section class="conteudo-home-descobertas-produto">

            <% if (produtos && produtos.length > 0) { %>

                <% produtos.forEach(produto => { %>
                    <div class="produto-item-grid" style="display: flex; flex-direction: column; justify-content: space-between; padding-bottom: 15px;">
                        
                        <section style="flex-grow: 1;">
                            <a href="/produtos/<%= produto._id %>" style="text-decoration: none; color: inherit; display: block;">
                                <img src="/img/<%= produto.foto %>" style="width: 100%; border-radius: 4px;">
                                
                                <p class="nome-produto" style="margin-top: 10px; font-size: 14px;"><%= produto.nome %></p>

                                <section class="produto-item-info" style="display: flex; justify-content: space-between; align-items: center; margin-top: 10px; margin-bottom: 15px;">
                                    <p class="valor-produto" data-valor="<%= produto.valor %>" style="color: #ee4d2d; font-size: 16px; font-weight: bold;">
                                        R$ <%= produto.valor %>
                                    </p>
                                    <p class="disponiveis" style="color: #999; font-size: 12px;">
                                        <%= produto.quantidade %> disp.
                                    </p>
                                </section>
                            </a>
                        </section>

                        <div style="border-top: 1px solid #eee; padding-top: 5px;">
                            <div class="cupom-box" style="display: flex; justify-content: space-between; gap: 8px;">
                                <input type="text" placeholder="Cupom" class="input-cupom" style="flex: 1; min-width: 0; padding: 6px 8px; border: 1px solid #ccc; border-radius: 3px; font-size: 12px; box-sizing: border-box;">
                                <button class="btn-aplicar-cupom" style="padding: 0 12px; background-color: #ee4d2d; color: white; border: none; border-radius: 3px; cursor: pointer; font-size: 12px; font-weight: bold; white-space: nowrap;">Aplicar</button>
                            </div>
                            
                            <p class="resultado-cupom" style="margin-top: 5px; font-size: 11px; text-align: center; min-height: 15px; color: #28a745;"></p>
                        </div>

                    </div>
                <% }) %>

            <% } else { %>
                <p style="text-align:center; width:100%; color: #666; margin-top: 20px;">
                    Nenhum produto cadastrado na loja ainda.
                </p>
            <% } %>

        </section>
        
    </section>
</section>

<footer class="rodape">
    <section class="conteudo-rodape-info">
        <section class="conteudo-rodape">
            <h5 id="rodape-titulo">Atendimento ao cliente</h5>
            <a href="#">Central de Ajuda</a>
            <a href="#">Como Comprar</a>
            <a href="#">Métodos de Paramento</a>
            <a href="#">Garantia Xhopii</a>
            <a href="#">Devolução e Reembolso</a>
            <a href="#">Fale Conosco</a>
            <a href="#">Ouridoria</a>
            <a href="#">Preferências de cookies</a>
        </section>

        <section class="conteudo-rodape">
            <h5 id="rodape-titulo">Sobre a Xhopii</h5>
            <a href="#">Sobre Nós</a>
            <a href="#">Políticas Xhopii</a>
            <a href="#">Política de Privacidade</a>
            <a href="#">Programa de Afiliados da Xhopii</a>
            <a href="#">Seja um Entregador Xhopii</a>
            <a href="#">Ofertas Relâmpago</a>
            <a href="#">Xhopii Blog</a>
            <a href="#">Imprensa</a>
        </section>

        <section class="conteudo-rodape">
            <h5 id="rodape-titulo">Pagamento</h5>
            <section class="conteudo-rodape-pagamento">
                <img id="img-pagamento" src="/img/logo-visa.png">
                <img id="img-pagamento" src="/img/logo-mastercard.png">
                <img id="img-pagamento" src="/img/logo-hipercard.png">
                <img id="img-pagamento" src="/img/logo-elo.png">
                <img id="img-pagamento" src="/img/logo-american-express.png">
                <img id="img-pagamento" src="/img/logo-boleto.png">
                <img id="img-pagamento" src="/img/logo-pix.png">
            </section>
        </section>

        <section class="conteudo-rodape">
            <h5 id="rodape-titulo">Siga-nos</h5>
            <a href="#"><img id="img-sociais" src="/img/logo-instagram.png">Instagram</a>
            <a href="#"><img id="img-sociais" src="/img/logo-tiktok.png">TikTok</a>
            <a href="#"><img id="img-sociais" src="/img/logo-twitter.png">X/Twitter</a>
            <a href="#"><img id="img-sociais" src="/img/logo-facebook.png">Facebook</a>
            <a href="#"><img id="img-sociais" src="/img/logo-linkedln.png">LinkedIn</a>
        </section>

        <section class="conteudo-rodape">
            <h5 id="rodape-titulo">Aplicativo</h5>
            <img id="img-store" src="/img/qr-code.png">
            <img id="img-store" src="/img/logo-store-apple.png">
            <img id="img-store" src="/img/logo-google-play.png">
        </section>
    </section>

    <hr>
    <p>© 2025 Xhopii. Todos os direitos acadêmicos reservados</p>
</footer>

<script src="/js/aplicarCupom.js"></script>

</body>
</html>